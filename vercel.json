{
  "functions": {
    "api/**/*": {
      "maxDuration": 60
    }
  },
  "crons": [
    {
      "path": "/api/run-scheduled",
      "schedule": "0 12 * * *"
    },
    {
      "path": "/api/growth-autopost",
      "schedule": "0 12 * * 1,3,5"
    }
  ],
  "rewrites": [
    { "source": "/", "destination": "/api" },
    { "source": "/strategy", "destination": "/api" },
    { "source": "/growth", "destination": "/api" },
    { "source": "/api/:path*", "destination": "/api" }
  ]
}
